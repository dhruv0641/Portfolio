# ═══════════════════════════════════════════════════════════
# Dhruvkumar Dobariya — Environment Variables Template
# Copy to .env and fill in actual values. Never commit .env
# ═══════════════════════════════════════════════════════════

# ─── Server ───
NODE_ENV=production
PORT=4000

# ─── Database (PostgreSQL via Prisma) ───
DATABASE_URL=postgresql://portfolio:CHANGE_ME@localhost:5432/portfolio_db?schema=public
DB_PASSWORD=CHANGE_ME

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── JWT (REQUIRED in production — use: openssl rand -hex 64) ───
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption (REQUIRED — use: openssl rand -hex 32) ───
ENCRYPTION_KEY=

# ─── Admin Credentials (REQUIRED in production) ───
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=

# ─── CORS ───
ALLOWED_ORIGINS=https://dhruvkumar.tech

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ─── Brute Force Protection ───
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ─── 2FA ───
TOTP_ISSUER=Dhruvkumar Dobariya Admin

# ─── Logging ───
LOG_LEVEL=info
