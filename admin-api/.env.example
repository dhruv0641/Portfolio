# ═══════════════════════════════════════════════════════════
# Dhruvkumar Dobariya — Production Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Server ───
PORT=4000
NODE_ENV=production

# ─── JWT Authentication ───
JWT_SECRET=CHANGE_ME_TO_A_SECURE_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_SECURE_RANDOM_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── AES-256 Encryption ───
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY_HERE_64_CHARS

# ─── CORS ───
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://127.0.0.1:3000

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ─── Brute Force Protection ───
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ─── 2FA ───
TOTP_ISSUER=Dhruvkumar Dobariya Admin

# ─── Logging ───
LOG_LEVEL=info

# ─── Email Notifications (SMTP) ───
# Gmail: use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=dhruvkumardobariya641@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
NOTIFY_EMAIL=dhruvkumardobariya641@gmail.com

# ─── Admin Initial Credentials ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
